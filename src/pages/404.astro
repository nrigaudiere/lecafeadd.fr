---
import { Button, Container, TextCardSection } from '@components/odyssey-theme'
import Layout from '../layouts/Page.astro'
import settings from './../config/settings'

const seo = {
  title: `Page introuvable | ${settings.name}`,
  description: 'La page que vous cherchez est introuvable.',
}
---

<Layout {seo}>
	<Container>
		<TextCardSection>
			<h1>404</h1>
			<h2>Page introuvable 👀</h2>
			<div class="cta-buttons__container">
				<Button href="/">Retourner à la page d'accueil</Button>
			</div>
		</TextCardSection>
	</Container>
</Layout>

<style>
	.cta-buttons__container {
		display: flex;
		flex-wrap: wrap;
	}
	.cta-buttons__container :global(a) {
		margin-right: 1rem;
		margin-bottom: 1rem;
	}
	.code-buttons__container {
		margin: 1rem auto;
		display: flex;
		flex-wrap: wrap;
	}
	.code-buttons__container > a {
		margin-right: 1rem;
		margin-bottom: 1rem;
	}
</style>
