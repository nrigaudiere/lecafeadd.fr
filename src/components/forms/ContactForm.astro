---
import { Button, FormInput, FormSelect, FormTextarea } from '@components/odyssey-theme'

const selectOptions = ['Google Search', 'Social Media', 'Email']
---

<form name="Contact Form" method="POST" action="/contact-thank-you">
  <FormInput type="text" label="Nom" name="Nom" placeholder="Jean Dupont" />
  <FormInput
    type="email"
    label="Email"
    name="Email"
    placeholder="jean.dupont@example.com"
  />
  <!-- <FormSelect label="How Did You Hear About Us?" options={selectOptions} /> -->
  <FormTextarea label="Message" name="Message" placeholder="Votre message..." />
  <Button>Envoyer</Button>
</form>

<style>
  form {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
</style>
